dist/
build/
eggs/
*.egg

# Test and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
venv/
.venv/
env/
.env//

# Coverage test
coverage.json
