# Raven Foundry - Environment Configuration

# Required API Keys
# Get your API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Get your API key at: https://openalex.org/
OPENALEX_API_KEY=your_openalex_api_key_here

# Optional: Groq model (defaults to openai/gpt-oss-120b)
GROQ_MODEL=openai/gpt-oss-120b

# Optional: OpenAlex API URL (defaults to https://api.openalex.org)
# OPENALEX_API_URL=https://api.openalex.org

# Optional: Custom data directory (defaults per OS)
# Override the default data directory location.
# Windows: %APPDATA%/raven
# macOS: ~/.config/raven (or $XDG_DATA_HOME/raven)
# Linux: ~/.config/raven (or $XDG_DATA_HOME/raven)
# RAVEN_DATA_DIR=/custom/path

# Placement: Place .env in one of these locations:
# 1. Current working directory (where you run raven commands)
# 2. Data directory (see above paths)
